---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact" description="Contact ObsidianFlow" pathname="/contact/">
  <section class="hero policy-hero"><p class="meta">Contact</p><h1>Contact ObsidianFlow</h1></section>
  <article class="policy-card prose">
<h2>GitHub Issues</h2>
<p>Use <a href="https://github.com/yangyangyang-25/obsidianflow/issues" rel="noopener noreferrer">the repository Issues page</a> for corrections, content feedback, and reproducible technical questions.</p>
<p class="policy-notice">Do not submit credentials, tokens, account identifiers, personal information, private notes, or other sensitive data.</p>
<p>There is no guarantee of individual support or a specific response time.</p>
  </article>
</BaseLayout>
